# Redis (Upstash) — necessário em produção na Vercel.
# A integração "Upstash for Redis" no Marketplace da Vercel cria estas variáveis
# automaticamente. Localmente você NÃO precisa preencher (usa memória).

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternativamente (mesmo efeito):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
